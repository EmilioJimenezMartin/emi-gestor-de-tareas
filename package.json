{
  "name": "emi-gestor-de-tareas",
  "version": "1.0.0",
  "description": "Monorepo: Next.js (web) + Fastify/MongoDB (api)",
  "private": true,
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "dev": "./dev.sh",
    "build": "npm --workspace apps/api run build && npm --workspace apps/web run build",
    "lint": "npm --workspace apps/web run lint",
    "start:api": "npm --workspace apps/api run start",
    "ngrok": "./ngrok-start.sh"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "devDependencies": {
    "concurrently": "^6.5.1"
  },
  "dependencies": {
    "@pdf-lib/fontkit": "^1.1.1",
    "pdf-lib": "^1.17.1"
  }
}
